        C1[Scrape /metrics]
    end
    subgraph Disk[Disk]
        D1[metrics.json]
    end
    
    A1 -- duration_ms --> Pipeline_Code
    A2 -- stage timing --> B1
    A2 -- stage timing --> B2
    A3 -- request timing --> B1
